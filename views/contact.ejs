<%- include('header') %>

<section class="contact-hero">
    <h1>Get In Touch</h1>
    <p>We are here to ensure your stay is nothing short of perfection.</p>
</section>

<main class="container section-padding">
    <div class="contact-wrapper">
        
        <div class="contact-info-panel">
            <div class="info-item">
                <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                <div class="info-text">
                    <h3>Our Location</h3>
                    <p>NO.31 Odunayo akinse avenue,<br>Abuja, Nigeria</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                <div class="info-text">
                    <h3>Phone & WhatsApp</h3>
                    <p><br>+234 816 238 7863</p>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="fas fa-envelope"></i></div>
                <div class="info-text">
                    <h3>Email Support</h3>
                    <p>reservations@dcalvins.com<br>info@dcalvins.com</p>
                </div>
            </div>

            <div class="social-links">
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href=""><i class="fab fa-facebook"></i></a>
                <a href="#"><i class="fab fa-tiktok"></i></a>
            </div>
        </div>

        <div class="contact-form-card">
            <h2>Send us a Message</h2>
            <form action="/submit-review" method="POST" class="hotel-form">
                <div class="form-group">
                    <label>Your Name</label>
                    <input type="text" name="name" placeholder="Enter your full name" required>
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="email@example.com" required>
                </div>
                <div class="form-group">
                    <label>Subject</label>
                    <select name="subject">
                        <option value="General Inquiry">General Inquiry</option>
                        <option value="Room Reservation">Room Reservation</option>
                        <option value="Spa Booking">Spa & Skin Therapy</option>
                        <option value="Events">Events & Hall Rental</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Message</label>
                    <textarea name="message" rows="5" placeholder="How can we help you?" required></textarea>
                </div>
                <button type="submit" class="btn-submit-contact">Send Message</button>
            </form>
        </div>
    </div>
</main>

<%- include('footer') %>