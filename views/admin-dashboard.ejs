<%- include('header') %>

<div class="dashboard-wrapper">
    <aside class="admin-sidebar">
        <div class="sidebar-user">
            <div class="avatar">D'Calvin</div>
            <p>Welcome, Admin</p>
        </div>
        <nav class="sidebar-nav">
            <a href="#" class="active"><i class="fas fa-chart-line"></i> Overview</a>
            <a href="#"><i class="fas fa-bed"></i> Room Status</a>
            <a href="#"><i class="fas fa-envelope"></i> Inquiries</a>
            <a href="#"><i class="fas fa-cog"></i> Settings</a>
        </nav>
    </aside>

    <main class="admin-main">
        <header class="admin-header">
            <h2>Business Overview</h2>
          <a href="/admin/export-report" class="btn-yellow" style="text-decoration: none;">
              <i class="fas fa-file-download"></i> Export Report
          </a>
        </header>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Revenue</h3>
                <p class="stat-value">&#8358;<%= stats.totalRevenue %></p>
            </div>
            <div class="stat-card">
                <h3>Active Bookings</h3>
                <p class="stat-value"><%= stats.activeBookings %></p>
            </div>
            <div class="stat-card">
                <h3>Occupancy</h3>
                <p class="stat-value"><%= stats.occupancyRate %></p>
            </div>
        </div>

        <div class="orders-section">
            <h3>Recent Booking Orders</h3>
           <table class="admin-table">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Guest Name</th>
            <th>Phone</th>
            <th>Room</th>
            <th>Status</th>
            <th>Actions</th> </tr>
    </thead>
    <tbody>
        <% orders.forEach(order => { %>
            <tr>
                <td><%= order.id %></td>
                <td><%= order.guest %></td>
                <td><%= order.phone %></td>
                <td><%= order.room %></td>
                <td><span class="status-tag"><%= order.status %></span></td>
                <td>
                    <form action="/admin/delete-booking/<%= order.id %>" method="POST" style="display:inline;">
                        <button type="submit" class="btn-delete" onclick="return confirm('Delete this booking?')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>
        </div>
    </main>
</div>

<%- include('footer') %>