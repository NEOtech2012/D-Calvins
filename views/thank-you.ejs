<%- include('header') %>

<main class="container section-padding" style="text-align: center; min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
    <div class="success-icon" style="font-size: 4rem; color: #27ae60; margin-bottom: 20px;">
        <i class="fas fa-check-circle"></i>
    </div>
    <h1 style="color: var(--primary-purple);">Reservation Received!</h1>

<div class="receipt-container">
    <div class="print-section" onclick="window.print()">
        <i class="fas fa-print"></i>
        <p>PRINT</p>
    </div>

    <p style="color: red;">Please send the receipt to our WhatsApp number to expedite the confirmation process. We look forward to hosting you soon!.</p> 
    
    <h2 class="make-payment-title">MAKE PAYMENT</h2>

    <div class="receipt-card">
    <div class="receipt-header-info">
        <h2 class="hotel-name-receipt">D'Calvins Hotel & Lounge</h2>
        <p class="hotel-location">Abuja, Nigeria</p>
        <p class="receipt-date"><%= new Date().toLocaleString() %></p>
    </div>

    <div class="receipt-divider">------------------------------------------</div>

    <div class="receipt-details">
        <p><strong>CUSTOMER:</strong> <span class="customer-data"><%= booking.guest.toUpperCase() %></span></p>
        <p><strong>PHONE:</strong> <span class="customer-data"><%= booking.phone %></span></p>
        
        <br>
        <p class="items-ordered-label">ITEMS ORDERED:</p>
        <p><strong><%= booking.room %></strong></p>
    </div>

    <div class="receipt-divider">------------------------------------------</div>

    <div class="receipt-pricing">
        <div class="price-row">
            <span>Subtotal:</span>
            <span>&#8358;<%= (booking.amount).toLocaleString() %></span>
        </div>
        <div class="price-row">
            <span>VAT (7.5%):</span>
            <span>&#8358;<%= (booking.amount - (booking.amount / 1.075)).toLocaleString() %></span>
        </div>
        
        <div class="total-row">
            <span>TOTAL:</span>
            <span>&#8358;<%= booking.amount.toLocaleString() %></span>
        </div>
    </div>

    <div class="account-details-box">
    <p class="account-label">Account Details:</p>
    <div class="account-info">
        <span class="bank-name">MoniePoint</span> | 
        <span class="account-holder">D'Calvins luxury limited| </span>
        <span class="account-number" style="cursor: pointer;" onclick="copyToClipboard('5180641871')">5180641871 <i class="far fa-copy" style="font-size: 0.8rem;"></i></span>
    </div>
</div>

    <p class="thanks-msg">*** THANK YOU FOR YOUR PATRONAGE ***</p>
</div>

    <div style="margin-top: 30px;">
    <% 
        // 1. Create the custom message
        let message = `Hello D'Calvins! I just booked a stay.%0A%0A` +
                      `*Name:* ${booking.guest}%0A` +
                      `*Room:* ${booking.room}%0A` +
                      `*Order ID:* ${booking.id}%0A%0A` +
                      `Please confirm my reservation.`;
        
        // 2. Set your business WhatsApp number here (e.g., 2348012345678)
        let myWhatsAppNumber = "2348162387863"; 
    %>

    <a href="https://wa.me/<%= myWhatsAppNumber %>?text=<%= message %>" 
       target="_blank" 
       class="btn-whatsapp" 
       style="background-color: #25D366; color: white; padding: 12px 25px; border-radius: 5px; text-decoration: none; display: inline-block; font-weight: bold;">
        <i class="fab fa-whatsapp"></i> Share Receipt to WhatsApp
    </a>

    <br><br>
    <a href="/" style="color: #666; text-decoration: none;">Back to Home</a>
</div>
</main>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text);
    alert("Account number copied to clipboard!");
}
</script>

<%- include('footer') %>