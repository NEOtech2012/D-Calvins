<%- include('header') %>

<main class="container section-padding" style="text-align: center; min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
    <div class="success-icon" style="font-size: 4rem; color: #27ae60; margin-bottom: 20px;">
        <i class="fas fa-check-circle"></i>
    </div>
    <h1 style="color: var(--primary-purple);">Reservation Received!</h1>
    <p style="font-size: 1.2rem; color: #666; max-width: 600px; margin: 10px auto 30px;">
        Thank you for choosing <strong>D'Calvins Luxury Hotel</strong>. We have received your booking details and our concierge will contact you shortly to confirm your stay.
       <p style="color: red;">Please send the receipt to our WhatsApp number to expedite the confirmation process. We look forward to hosting you soon!.</p> 
    </p>
    <div style="margin-top: 30px;">
    <% 
        // 1. Create the custom message
        let message = `Hello D'Calvins! I just booked a stay.%0A%0A` +
                      `*Name:* ${booking.guest}%0A` +
                      `*Room:* ${booking.room}%0A` +
                      `*Order ID:* ${booking.id}%0A%0A` +
                      `Please confirm my reservation.`;
        
        // 2. Set your business WhatsApp number here (e.g., 2348012345678)
        let myWhatsAppNumber = "2348162387863"; 
    %>

    <a href="https://wa.me/<%= myWhatsAppNumber %>?text=<%= message %>" 
       target="_blank" 
       class="btn-whatsapp" 
       style="background-color: #25D366; color: white; padding: 12px 25px; border-radius: 5px; text-decoration: none; display: inline-block; font-weight: bold;">
        <i class="fab fa-whatsapp"></i> Share Receipt to WhatsApp
    </a>

    <br><br>
    <a href="/" style="color: #666; text-decoration: none;">Back to Home</a>
</div>
</main>

<%- include('footer') %>